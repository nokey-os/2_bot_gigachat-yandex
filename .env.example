# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Прямой IP для api.telegram.org (основной способ обхода блокировок)
# Рабочие IP: 149.154.167.220, 149.154.167.221, 149.154.167.222, 91.108.56.100
# TELEGRAM_API_IP=149.154.167.220

# Прокси для Telegram API (если не работает прямой IP — через VPN/Tor)
# TELEGRAM_PROXY=socks5://127.0.0.1:9150

# === GigaChat (Сбер) ===
# AUTHORIZATION_KEY=your_gigachat_key
# GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
# GIGACHAT_VERIFY_SSL_CERTS=false
# GIGACHAT_TIMEOUT=120
# GIGACHAT_SYSTEM_PROMPT=Ты вежливый и профессиональный личный помощник

# === YandexGPT (Яндекс) ===
# YC_API_KEY=your_yandex_cloud_api_key
# YC_FOLDER_ID=your_yandex_cloud_folder_id
# YC_MODEL_NAME=yandexgpt-lite
# YANDEX_SYSTEM_PROMPT=Ты полезный AI-ассистент. Отвечай кратко и по делу.
